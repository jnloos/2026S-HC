# Copy to .env and fill in real values. .env is gitignored.

# Anthropic — required for /pools/{id}/choose-by-group and /choose-by-img.
ANTHROPIC_API_KEY=
# Optional overrides:
# CLAUDE_MODEL=claude-haiku-4-5
# CLAUDE_MAX_TOKENS=1024

# Debug UI at /debug — off by default. Set to true for the demo/dev box.
DEBUG_UI_ENABLED=false
# Empty = no auth (fine on localhost / trusted LAN).
# Non-empty = requests to /debug/* require ?token=... or `Authorization: Bearer ...`.
DEBUG_TOKEN=
