# Runtime overrides for the DigSig Arduino app — loaded by python/config.py.
#
# Copy to runtime.env (gitignored) or let the helpers manage it:
#   ./cli/dev.sh up                 # start API + auto-detect laptop IP -> CMS_URL + sync + restart
#   ./cli/configure.sh              # auto-detect IP -> CMS_URL only, then sync + restart
#   ./cli/configure.sh KEY=VALUE    # set any key, e.g. TRIGGER_MODE=timer
#
# Values here take PRECEDENCE over the ambient environment, so this file is
# authoritative. After editing by hand, apply with:
#   ./cli/rsync.sh push && ./cli/control.sh restart

# CMS (FastAPI) base URL the board talks to. On the board, "localhost" is the
# board itself — for full-stack dev point this at the laptop, via the Caddy
# reverse-proxy on port 80 (path /digsig -> uvicorn:8000). Managed by
# cli/configure.sh / cli/dev.sh (auto-detected laptop IP), so the placeholder
# below is illustrative — don't hand-edit the IP, run the helpers.
CMS_URL=http://<laptop-ip>/digsig

POOL_ID=1

# Variant pipeline: edge (V1, on-device LLM) | hybrid (V2) | cloud (V3).
SELECTOR_MODE=edge

# Audience source: static (fixed AUDIENCE_GROUP) | face (in-process inference,
# needs the camera). AUDIENCE_GROUP is used only in static mode.
AUDIENCE_MODE=static
AUDIENCE_GROUP=general

# person | timer
TRIGGER_MODE=person
TIMER_INTERVAL_SEC=30
PERSON_DEBOUNCE_SEC=5
# Set false to free CPU for the on-device LLM (forces the person trigger to timer).
ENABLE_CAMERA=true

# Debug event channel + camera PiP in the board UI.
DEBUG=true
